{
  "DatabaseProvider": "mysql",
  "ConnectionStrings": {
    "MySQL": "Server=localhost;Port=3306;Database=blog_bank;User=root;Password=root;CharSet=utf8mb4;",
    "PostgreSQL": "Host=localhost;Port=5432;Database=blog_bank;Username=postgres;Password=root;"
  },
  "Jwt": {
    "SecretKey": "your-256-bit-secret-key-here-change-in-production",
